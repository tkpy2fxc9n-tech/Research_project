#!/bin/bash
#SBATCH --job-name=full_rollout_gaussian_wave
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --mem=128G
#SBATCH --time=6:00:00
#SBATCH --output=logs/full_rollout_gaussian_wave_%j.log
#SBATCH --error=logs/full_rollout_gaussian_wave_%j.err
#SBATCH --partition=short

set -euo pipefail

# To be launched from training/ (cd The_surrogate_model/full_rollout_training_gaussian_wave/training &&
# sbatch code/full_rollout_training_gaussian_wave.job) -- logs/ above and
# mkdir -p logs below are therefore relative to training/, consistent with the
# training/{code,logs,plots} structure. code/ contains main.py (plots ->
# training/plots/simulation_<day>/, model -> full_rollout_training_gaussian_wave/model.pth,
# see PLOTS_DIR/PROJECT_DIR in main.py).
cd /home/aph25/Building_surrogate_model/The_surrogate_model/full_rollout_training_gaussian_wave/training

# logs/ must exist BEFORE Slurm starts the job (the --output/--error paths
# above are opened as soon as it launches, before the first line of the
# script) -- already created, but recreated here in case the folder was
# deleted between two runs.
mkdir -p logs
# Cleans up logs from previous runs (without touching those of the current
# job, already opened by Slurm at launch).
find logs -maxdepth 1 -type f ! -name "*${SLURM_JOB_ID}*" -delete

# 1 thread per process: generate_dataset spreads the FD simulations across
# the allocated cpus via ProcessPoolExecutor (like in
# Code_comparaison_des_inputs/commun.job) -- a higher OMP_NUM_THREADS would
# oversubscribe the cpus. Training itself is forced to 1 thread anyway by
# commun.py (torch.set_num_threads(1)).
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1

PYTHON=/home/aph25/Desktop/wave_env/bin/python

# Same training hyperparameters as Current_model (300 epochs,
# tbptt-hops=5, group-size=4) -- only the grid changes (main.py:
# CONFIG_OVERRIDES, N_GRID=20 i.e. 400 Gaussian simulations instead of
# 100, A:0.005-0.15, omega:1-10). ~4x more training pairs -> time
# and memory adjusted above accordingly. Estimate ~5.3-5.8h, so at
# the edge of the 6h short partition limit (linear extrapolation, not a
# measurement -- margin of error possible): if the job is killed before
# the end, model.pth (saved at every epoch that improves validation) and
# norm_stats.csv (next to model.pth) remain usable by test_prediction.py, just
# with a less trained model than intended. Switch to the medium partition
# (--time=10:00:00) if you want the guarantee of completing all 300 epochs.
time "$PYTHON" -u code/main.py --epochs 300 --tbptt-hops 5 --group-size 4

echo "FULL_ROLLOUT_TRAINING_GAUSSIAN_WAVE JOB DONE"
