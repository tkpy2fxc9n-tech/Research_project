#!/bin/bash
#SBATCH --job-name=full_rollout_multisignal
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --mem=128G
#SBATCH --time=14:00:00
#SBATCH --output=logs/full_rollout_multisignal_%j.log
#SBATCH --error=logs/full_rollout_multisignal_%j.err
#SBATCH --partition=medium

set -euo pipefail

# To be launched from training/ (cd Model_in_tests/full_rollout_training_multisignal/training &&
# sbatch code/full_rollout_training_multisignal.job) -- logs/ above and
# mkdir -p logs below are therefore relative to training/, consistent with the
# training/{code,logs,plots} structure. code/ contains main.py (plots ->
# training/plots/simulation_<day>/, model -> full_rollout_training_multisignal/model.pth,
# see PLOTS_DIR/PROJECT_DIR in main.py).
cd /home/aph25/Building_surrogate_model/Model_in_tests/full_rollout_training_multisignal/training

# logs/ must exist BEFORE Slurm starts the job (the --output/--error paths
# above are opened as soon as it launches, before the first line of the
# script) -- already created, but recreated here in case the folder was
# deleted between two runs.
mkdir -p logs
# Cleans up logs from previous runs (without touching those of the current
# job, already opened by Slurm at launch).
find logs -maxdepth 1 -type f ! -name "*${SLURM_JOB_ID}*" -delete

# 1 thread per process: dataset_multisignal.generate_dataset_multisignal
# spreads the FD simulations across the allocated cpus via
# ProcessPoolExecutor -- a higher OMP_NUM_THREADS would oversubscribe the
# cpus. Training itself is forced to 1 thread anyway by commun.py
# (torch.set_num_threads(1)).
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1

PYTHON=/home/aph25/Desktop/wave_env/bin/python

# Before running this for real: `python code/check_equivalence.py` should
# print all-OK first (confirms the torch training path and the numpy
# reference path agree on all 7 signal families + the new free-evolution
# physics). Consider a `--smoke-test` run too if this is the first run after
# a code change.
#
# Wall-time budget: measured locally (same venv/cpu) that one training hop
# costs ~9.16ms of raw forward+backward compute for this network
# (512,256,64 hidden, M_BACK=4/N_FWD=4) vs ~1.45ms for the old
# full_rollout_training_gaussian_wave network (64,32,16, M_BACK=2/N_FWD=2)
# -- a 6.3x slowdown per hop, but each rollout now only takes ~40 hops
# instead of ~82 (N_FWD=4 jumps twice as far per hop), so the net effect is
# only ~3.1x slower per epoch, not ~6.3x. Scaled from the old project's
# measured 300-epoch run (166 min real, 32.9s/epoch, 400 sims, group-size=4):
# ~101s/epoch expected here -> ~8.5h for 300 epochs. That's already past the
# 6h `short` partition the other full_rollout_training_* projects use, so
# this job runs on `medium` (24h limit) instead, with --time=14:00:00 for
# a ~1.6x safety margin over the estimate (this is a scaled estimate, not a
# direct measurement of this exact job -- if it still runs long, model.pth is
# saved at every epoch that improves validation, so a partial run remains
# usable by test_prediction.py either way).
time "$PYTHON" -u code/main.py --epochs 300 --tbptt-hops 5 --group-size 4

echo "FULL_ROLLOUT_TRAINING_MULTISIGNAL JOB DONE"
