#!/bin/bash
#SBATCH --job-name=full_rollout_gaussian_wave
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --mem=128G
#SBATCH --time=6:00:00
#SBATCH --output=logs/full_rollout_gaussian_wave_%j.log
#SBATCH --error=logs/full_rollout_gaussian_wave_%j.err
#SBATCH --partition=short

set -euo pipefail

# À lancer depuis training/ (cd full_rollout_training_gaussian_wave/training &&
# sbatch code/full_rollout_training_gaussian_wave.job) -- logs/ ci-dessus et
# mkdir -p logs ci-dessous sont donc relatifs à training/, cohérent avec la
# structure training/{code,logs,plots}. code/ contient main.py (plots ->
# training/plots/simulation_<jour>/, modèle -> full_rollout_training_gaussian_wave/model.pth,
# cf. PLOTS_DIR/PROJECT_DIR dans main.py).
cd /home/aph25/Building_surrogate_model/full_rollout_training/full_rollout_training_gaussian_wave/training

# logs/ doit exister AVANT que Slurm ne démarre le job (les chemins
# --output/--error ci-dessus sont ouverts dès le lancement, avant la
# première ligne du script) -- déjà créé, mais recréé ici au cas où le
# dossier aurait été supprimé entre deux runs.
mkdir -p logs
# Nettoie les logs des runs précédents (sans toucher à ceux du job en cours,
# déjà ouverts par Slurm au lancement).
find logs -maxdepth 1 -type f ! -name "*${SLURM_JOB_ID}*" -delete

# 1 thread par processus : generate_dataset répartit les simulations FD sur
# les cpus alloués via ProcessPoolExecutor (comme dans
# Code_comparaison_des_inputs/commun.job) -- un OMP_NUM_THREADS plus élevé
# ferait sursouscrire les cpus. L'entraînement lui-même est de toute façon
# forcé à 1 thread par commun.py (torch.set_num_threads(1)).
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1

PYTHON=/home/aph25/Desktop/wave_env/bin/python

# Mêmes hyperparamètres d'entraînement que Current_model (300 epochs,
# tbptt-hops=5, group-size=4) -- seule la grille change (main.py:
# CONFIG_OVERRIDES, N_GRID=20 soit 400 simulations gaussiennes au lieu de
# 100, A:0.005-0.15, omega:1-10). ~4x plus de paires d'entraînement -> temps
# et mémoire adaptés ci-dessus en conséquence. Estimation ~5.3-5.8h, donc à
# la limite des 6h de la partition short (extrapolation linéaire, pas une
# mesure -- marge d'erreur possible) : si le job est tué avant la fin,
# model.pth (sauvegardé à chaque epoch qui améliore la validation) et
# norm_stats.csv (à côté de model.pth) restent exploitables par test_prediction.py, juste
# avec un modèle moins entraîné que prévu. Repasser en partition medium
# (--time=10:00:00) si on veut la garantie d'aller au bout des 300 epochs.
time "$PYTHON" -u code/main.py --epochs 300 --tbptt-hops 5 --group-size 4

echo "FULL_ROLLOUT_TRAINING_GAUSSIAN_WAVE JOB DONE"
