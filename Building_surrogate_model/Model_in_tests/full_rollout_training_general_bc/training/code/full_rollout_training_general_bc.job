#!/bin/bash
#SBATCH --job-name=full_rollout_general_bc
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --mem=128G
#SBATCH --time=6:00:00
#SBATCH --output=logs/full_rollout_general_bc_%j.log
#SBATCH --error=logs/full_rollout_general_bc_%j.err
#SBATCH --partition=short

set -euo pipefail

# To be launched from training/ (cd Model_in_tests/full_rollout_training_general_bc/training &&
# sbatch code/full_rollout_training_general_bc.job) -- logs/ above and
# mkdir -p logs below are therefore relative to training/, consistent with the
# training/{code,logs,plots} structure. code/ contains main.py (plots ->
# training/plots/simulation_<day>/, model -> full_rollout_training_general_bc/model.pth,
# see PLOTS_DIR/PROJECT_DIR in main.py).
cd /home/aph25/Building_surrogate_model/Model_in_tests/full_rollout_training_general_bc/training

# logs/ must exist BEFORE Slurm starts the job (the --output/--error paths
# above are opened as soon as it launches, before the first line of the
# script) -- already created, but recreated here in case the folder was
# deleted between two runs.
mkdir -p logs
# Cleans up logs from previous runs (without touching those of the current
# job, already opened by Slurm at launch).
find logs -maxdepth 1 -type f ! -name "*${SLURM_JOB_ID}*" -delete

# 1 thread per process: generate_dataset_general spreads the FD simulations
# across the allocated cpus via ProcessPoolExecutor -- a higher
# OMP_NUM_THREADS would oversubscribe the cpus. Training itself is forced to
# 1 thread anyway by commun.py (torch.set_num_threads(1)).
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1

PYTHON=/home/aph25/Desktop/wave_env/bin/python

# Before running this for real: `python code/check_equivalence.py` should
# print all-OK first (confirms the torch training path and the numpy
# reference path agree on the new Dirichlet/Neumann physics). Consider a
# `--smoke-test` run too if this is the first run after a code change.
#
# Same training hyperparameters as full_rollout_training_gaussian_wave (300
# epochs, tbptt-hops=5, group-size=4) as a starting point -- revisit if the
# richer boundary-condition space (vs. a single Gaussian family) turns out to
# need more updates to converge.
time "$PYTHON" -u code/main.py --epochs 300 --tbptt-hops 5 --group-size 4

echo "FULL_ROLLOUT_TRAINING_GENERAL_BC JOB DONE"
