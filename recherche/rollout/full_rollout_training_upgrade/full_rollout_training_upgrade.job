#!/bin/bash
#SBATCH --job-name=full_rollout_lr5e-3
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=72
#SBATCH --mem=80G
#SBATCH --time=2:30:00
#SBATCH --output=logs/full_rollout_lr5e-3_%j.log
#SBATCH --error=logs/full_rollout_lr5e-3_%j.err
#SBATCH --partition=short

set -euo pipefail

# logs/ doit exister AVANT que Slurm ne démarre le job (les chemins
# --output/--error ci-dessus sont ouverts dès le lancement, avant la
# première ligne du script) -- déjà créé, mais recréé ici au cas où le
# dossier aurait été supprimé entre deux runs.
mkdir -p logs
# Nettoie les logs des runs précédents (sans toucher à ceux du job en cours,
# déjà ouverts par Slurm au lancement).
find logs -maxdepth 1 -type f ! -name "*${SLURM_JOB_ID}*" -delete

# 1 thread par processus : generate_dataset répartit les 100 simulations FD
# sur les cpus alloués via ProcessPoolExecutor (comme dans
# Code_comparaison_des_inputs/commun.job) -- un OMP_NUM_THREADS plus élevé
# ferait sursouscrire les cpus. L'entraînement lui-même est de toute façon
# forcé à 1 thread par commun.py (torch.set_num_threads(1)).
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1

cd /home/aph25/recherche/rollout/full_rollout_training_upgrade

PYTHON=/home/aph25/Desktop/wave_env/bin/python

# Mêmes hyperparametres que full_rollout_training/full_rollout_training.job
# (300 epochs, tbptt-hops=5, group-size=4) -- seul LEARNING_RATE change (5e-3
# au lieu de 1e-3, mis dans main.py). Comparaison a l'identique pour voir si
# un taux d'apprentissage plus agressif converge mieux/plus vite sur le
# rollout complet.
time "$PYTHON" -u main.py --epochs 300 --tbptt-hops 5 --group-size 4

echo "FULL_ROLLOUT_TRAINING_UPGRADE JOB DONE"
