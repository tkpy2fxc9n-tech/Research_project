#!/bin/bash
#SBATCH --job-name=full_rollout
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --mem=64G
#SBATCH --time=2:30:00
#SBATCH --output=logs/full_rollout_%j.log
#SBATCH --error=logs/full_rollout_%j.err
#SBATCH --partition=short

set -euo pipefail

# To be launched from training/ (cd Model_in_tests/full_rollout_training/training && sbatch code/full_rollout_training.job) --
# logs/ above and mkdir -p logs below are therefore relative to training/,
# consistent with the training/{code,logs,plots} structure. code/ contains
# main.py (plots -> training/plots/simulation_<day>/, model ->
# Model_in_tests/full_rollout_training/model.pth, see PLOTS_DIR/PROJECT_DIR in main.py).
cd /home/aph25/Tests_archives/Model_in_tests/full_rollout_training/training

# logs/ must exist BEFORE Slurm starts the job (the --output/--error paths
# above are opened as soon as it launches, before the first line of the
# script) -- already created, but recreated here in case the folder was
# deleted between two runs.
mkdir -p logs
# Cleans up logs from previous runs (without touching those of the current
# job, already opened by Slurm at launch).
find logs -maxdepth 1 -type f ! -name "*${SLURM_JOB_ID}*" -delete

# 1 thread per process: generate_dataset spreads the 100 FD simulations
# across the allocated cpus via ProcessPoolExecutor (like in
# Code_comparaison_des_inputs/commun.job) -- a higher OMP_NUM_THREADS would
# oversubscribe the cpus. Training itself is forced to 1 thread anyway by
# commun.py (torch.set_num_threads(1)).
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1

PYTHON=/home/aph25/Desktop/wave_env/bin/python

# 300 epochs x 23 groups x 17 corrections/group (82 hops / tbptt-hops=5)
# = ~117,300 weight corrections -- deliberately at least as many as the
# ~114,620 updates of the existing pushforward method (2,934,000 train
# rows / 512 per batch x 20 epochs), to avoid concluding too early from
# insufficient training. group-size reduced to 4 (instead of 8) and
# tbptt-hops to 5 (instead of 10) to multiply the corrections without
# multiplying the compute time as much (calibrated at ~17s/epoch on the
# full grid, see exchange with Claude on 2026-07-20 -- readjust --epochs
# if a future config change alters this time).
time "$PYTHON" -u code/main.py --epochs 300 --tbptt-hops 5 --group-size 4

echo "FULL_ROLLOUT_TRAINING JOB DONE"
