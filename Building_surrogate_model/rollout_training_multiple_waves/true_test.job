#!/bin/bash
#SBATCH --job-name=true_test
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=64
#SBATCH --mem=64G
#SBATCH --time=5:00:00
#SBATCH --output=logs/true_test_%j.log
#SBATCH --error=logs/true_test_%j.err
#SBATCH --partition=short

set -euo pipefail

# logs/ doit exister AVANT que Slurm ne démarre le job (les chemins
# --output/--error ci-dessus sont ouverts dès le lancement, avant la
# première ligne du script) -- déjà créé, mais recréé ici au cas où le
# dossier aurait été supprimé entre deux runs.
mkdir -p logs
# Nettoie les logs des runs précédents (sans toucher à ceux du job en cours,
# déjà ouverts par Slurm au lancement).
find logs -maxdepth 1 -type f ! -name "*${SLURM_JOB_ID}*" -delete

# 1 thread par processus : generate_dataset_multi répartit les 200
# simulations FD (2 wave_types x grille 10x10) sur les cpus alloués via
# ProcessPoolExecutor (comme dans Code_comparaison_des_inputs/commun.job) --
# un OMP_NUM_THREADS plus élevé ferait sursouscrire les cpus. cpus-per-task
# relevé à 64 (nœuds de la partition short : 80 à 128 cpus chacun, plusieurs
# entièrement libres) pour accélérer cette étape, désormais 2x plus grosse.
# L'entraînement lui-même (la boucle d'epochs, dominante en temps) reste
# séquentiel et forcé à 1 thread par commun.py (torch.set_num_threads(1)) --
# plus de cpus n'accélère PAS cette partie, seulement la génération initiale
# du dataset.
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export VECLIB_MAXIMUM_THREADS=1

cd /home/aph25/recherche/rollout/rollout_training_multiple_waves

PYTHON=/home/aph25/Desktop/wave_env/bin/python

# 300 epochs x 23 groupes x 17 corrections/groupe (82 hops / tbptt-hops=5)
# = ~117 300 corrections de poids -- volontairement au moins autant que les
# ~114 620 mises à jour de la méthode pushforward existante (2 934 000
# lignes train / 512 par batch x 20 epochs), pour ne pas conclure trop tôt
# faute d'entraînement suffisant. group-size réduit à 4 (au lieu de 8) et
# tbptt-hops à 5 (au lieu de 10) pour multiplier les corrections sans
# multiplier d'autant le temps de calcul (calibré à ~17s/epoch sur la
# grille complète, cf. échange avec Claude du 20/07/2026 -- réajuster
# --epochs si un futur changement de config modifie ce temps).
# NB : depuis l'ajout de wave_forcing.py (2 wave_types), le nombre de
# simulations d'entraînement double (~180 paires train au lieu de ~90), donc
# le temps par epoch double aussi mécaniquement (~34s/epoch estimé, non
# revérifié) -- --time relevé à 5:00:00 par sécurité. À réajuster (epochs
# et/ou --time) après avoir observé le temps réel d'une epoch sur ce job.
time "$PYTHON" -u main.py --epochs 300 --tbptt-hops 5 --group-size 4

echo "TRUE_TEST JOB DONE"
